# .NET 10 .gitignore
# Basado en la plantilla oficial de GitHub para .NET

## Compilación de Visual Studio
[Bb]in/
[Oo]bj/

# Archivos de usuario de Visual Studio
*.user
*.suo
*.userosscache
*.sln.docstates

# Archivos de configuración de Visual Studio
*.vspscc
*.vssscc
*.dbmdl
*.pdb
*.cache
*.log
*.vs/

# Archivos de publicación
publish/

# Paquetes NuGet
*.nupkg
# Archivos de bloqueo de NuGet
project.lock.json
project.fragment.lock.json
artifacts/

# Archivos de configuración de Rider
.idea/
*.sln.iml

# Archivos de configuración de Visual Studio Code
.vscode/

# Archivos de configuración de Mac
.DS_Store

# Archivos de configuración de Windows
Thumbs.db

# Archivos de configuración de Linux
*~

# Archivos de test result
TestResults/

# Archivos generados por dotnet watch
**/node_modules/

# Archivos de configuración de usuario
*.swp
*.bak
*.tmp

# Archivos de configuración de JetBrains Rider
.idea/
*.sln.iml

# Archivos de configuración de Azure
.terraform/
