@model InterfazGraficaMVC_SQL.Entities.Persona

@{
    ViewData["Title"] = "Editar persona";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">Editar persona</h1>
        <p class="text-muted mb-0">Actualice la información del registro seleccionado.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary" title="Volver al listado de personas">Volver al listado</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form asp-action="Edit" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <input type="hidden" asp-for="Id" />

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ingrese el nombre" title="Nombre de la persona" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Apellido" class="form-label"></label>
                    <input asp-for="Apellido" class="form-control" placeholder="Ingrese el apellido" title="Apellido de la persona" />
                    <span asp-validation-for="Apellido" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Edad" class="form-label"></label>
                    <input asp-for="Edad" class="form-control" placeholder="Ingrese la edad" title="Edad en años" />
                    <span asp-validation-for="Edad" class="text-danger"></span>
                </div>

                <div class="col-md-8">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" placeholder="nombre@dominio.com" title="Correo electrónico de contacto" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Guardar cambios</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
